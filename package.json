{
    "name": "avatio",
    "version": "1.9.3",
    "private": true,
    "author": "Liria",
    "repository": {
        "type": "git",
        "url": "https://github.com/liria24/avatio.git"
    },
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "bun run --filter '@avatio/bot-notifier' build && bun run --filter '@avatio/ungh' build && nuxt prepare",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:unit": "vitest --project unit",
        "test:nuxt": "vitest --project nuxt",
        "release": "bumpp",
        "drizzle:generate": "drizzle-kit generate",
        "changelogen": "changelogen --hideAuthorEmail"
    },
    "dependencies": {
        "@avatio/bot-notifier": "workspace:*",
        "@avatio/ungh": "workspace:*",
        "@better-auth/drizzle-adapter": "1.6.11",
        "@comark/nuxt": "0.2.1",
        "@iconify-json/fluent-color": "1.2.21",
        "@iconify-json/lucide": "1.2.107",
        "@iconify-json/mingcute": "1.2.7",
        "@iconify-json/simple-icons": "1.2.82",
        "@iconify-json/svg-spinners": "1.2.4",
        "@iconify-json/twemoji": "1.2.5",
        "@neondatabase/serverless": "1.1.0",
        "@nuxt/content": "3.13.0",
        "@nuxt/image": "2.0.0",
        "@nuxt/ui": "4.7.1",
        "@nuxtjs/device": "4.0.0",
        "@nuxtjs/i18n": "10.3.0",
        "@nuxtjs/robots": "6.0.8",
        "@nuxtjs/sitemap": "8.0.15",
        "@stefanobartoletti/nuxt-social-share": "3.0.0",
        "@takumi-rs/core": "^1.1.2",
        "@tigrisdata/storage": "^3.6.0",
        "@unosend/node": "^3.0.0",
        "@vercel/analytics": "2.0.1",
        "@vercel/config": "^0.4.0",
        "@vercel/edge-config": "1.4.3",
        "@vercel/functions": "3.5.1",
        "@vite-pwa/nuxt": "1.1.1",
        "@vueuse/nuxt": "14.3.0",
        "@vueuse/router": "^14.3.0",
        "@yeger/vue-masonry-wall": "6.1.1",
        "ai": "6.0.182",
        "aws4fetch": "^1.0.20",
        "better-auth": "1.6.11",
        "canvas-confetti": "1.9.4",
        "clsx": "2.1.1",
        "drizzle-orm": "1.0.0-rc.2",
        "extract-colors": "4.2.1",
        "http-status-codes": "^2.3.0",
        "motion-v": "^2.2.1",
        "nuxt": "4.4.5",
        "nuxt-link-checker": "5.0.10",
        "nuxt-og-image": "^6.5.0",
        "nuxt-schema-org": "6.0.4",
        "nuxt-seo-utils": "8.1.11",
        "rfc2047": "^4.0.1",
        "sanitize-html": "2.17.4",
        "vue-data-ui": "3.19.6",
        "vue-draggable-plus": "0.6.1",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@nuxt/a11y": "1.0.0-alpha.1",
        "@nuxt/hints": "1.1.1",
        "@nuxt/test-utils": "4.0.3",
        "@types/canvas-confetti": "1.9.0",
        "@types/node": "25.7.0",
        "@types/rfc2047": "^2.0.3",
        "@types/sanitize-html": "2.16.1",
        "@vue/test-utils": "^2.4.10",
        "bumpp": "11.1.0",
        "drizzle-kit": "1.0.0-rc.2",
        "oxfmt": "^0.49.0",
        "oxlint": "^1.64.0",
        "taze": "^19.11.0",
        "typescript": "6.0.3",
        "vitest": "^4.1.6"
    },
    "overrides": {
        "vite": "^8.0.0",
        "vue": "latest"
    },
    "engines": {
        "node": "24.x"
    },
    "packageManager": "bun@1.3.14"
}
