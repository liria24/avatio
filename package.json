{
    "name": "avatio",
    "version": "1.9.2",
    "private": true,
    "author": "Liria",
    "repository": {
        "type": "git",
        "url": "https://github.com/liria24/avatio.git"
    },
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "bun run --filter '@avatio/bot-notifier' build && bun run --filter '@avatio/ungh' build && nuxt prepare",
        "check": "vp check",
        "check:fix": "vp check --fix",
        "test": "vp test",
        "test:watch": "vp test --watch",
        "test:unit": "vp test --project unit",
        "test:nuxt": "vp test --project nuxt",
        "release": "npx bumpp",
        "drizzle:generate": "npx drizzle-kit generate",
        "changelogen": "npx changelogen --hideAuthorEmail"
    },
    "dependencies": {
        "@avatio/bot-notifier": "workspace:*",
        "@avatio/ungh": "workspace:*",
        "@better-auth/drizzle-adapter": "1.6.2",
        "@comark/nuxt": "^0.2.1",
        "@iconify-json/fluent-color": "1.2.21",
        "@iconify-json/lucide": "1.2.102",
        "@iconify-json/mingcute": "1.2.7",
        "@iconify-json/simple-icons": "1.2.78",
        "@iconify-json/svg-spinners": "1.2.4",
        "@iconify-json/twemoji": "1.2.5",
        "@neondatabase/serverless": "1.0.2",
        "@nuxt/content": "3.13.0",
        "@nuxt/image": "2.0.0",
        "@nuxt/ui": "4.6.1",
        "@nuxtjs/device": "4.0.0",
        "@nuxtjs/i18n": "10.2.4",
        "@nuxtjs/robots": "6.0.7",
        "@nuxtjs/sitemap": "8.0.12",
        "@stefanobartoletti/nuxt-social-share": "3.0.0",
        "@takumi-rs/core": "^1.0.9",
        "@tigrisdata/storage": "^3.0.0",
        "@unosend/node": "^2.1.0",
        "@vercel/analytics": "2.0.1",
        "@vercel/config": "^0.1.1",
        "@vercel/edge-config": "1.4.3",
        "@vercel/functions": "3.4.3",
        "@vite-pwa/nuxt": "1.1.1",
        "@vueuse/nuxt": "14.2.1",
        "@vueuse/router": "^14.2.1",
        "@yeger/vue-masonry-wall": "6.1.0",
        "ai": "6.0.159",
        "aws4fetch": "^1.0.20",
        "better-auth": "1.6.2",
        "canvas-confetti": "1.9.4",
        "clsx": "2.1.1",
        "drizzle-orm": "1.0.0-beta.21",
        "extract-colors": "4.2.1",
        "http-status-codes": "^2.3.0",
        "motion-v": "^2.2.1",
        "nuxt": "4.4.2",
        "nuxt-link-checker": "5.0.9",
        "nuxt-og-image": "^6.4.0",
        "nuxt-schema-org": "6.0.4",
        "nuxt-seo-utils": "8.1.7",
        "rfc2047": "^4.0.1",
        "sanitize-html": "2.17.2",
        "vue-data-ui": "3.17.13",
        "vue-draggable-plus": "0.6.1",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@nuxt/a11y": "1.0.0-alpha.1",
        "@nuxt/hints": "1.0.3",
        "@nuxt/test-utils": "4.0.2",
        "@types/canvas-confetti": "1.9.0",
        "@types/node": "25.6.0",
        "@types/rfc2047": "^2.0.3",
        "@types/sanitize-html": "2.16.1",
        "@vue/test-utils": "^2.4.6",
        "bumpp": "10.4.1",
        "drizzle-kit": "1.0.0-beta.21",
        "taze": "^19.11.0",
        "typescript": "6.0.2",
        "vite-plus": "^0.1.16"
    },
    "overrides": {
        "vite": "8.0.7",
        "vue": "latest"
    },
    "engines": {
        "node": "24.x"
    },
    "packageManager": "bun@1.3.12"
}
